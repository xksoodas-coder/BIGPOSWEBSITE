# Copy these into Vercel → Project → Settings → Environment Variables.
# Never commit the real values.

# Turso database (same one DigiSoftApp pushes to).
# Example: libsql://bigsoft-sync-haithem.turso.io
TURSO_DATABASE_URL=

# Turso read/write auth token (create via: turso db tokens create <db-name>)
TURSO_AUTH_TOKEN=

# Random string used to sign customer session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BWS_SESSION_SECRET=
